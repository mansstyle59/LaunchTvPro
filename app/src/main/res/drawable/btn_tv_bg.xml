<?xml version="1.0" encoding="utf-8"?>
<!-- btn_tv_bg.xml - Fond des boutons avec état focus TV -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#2200D4FF" />
            <stroke android:width="2dp" android:color="#00D4FF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#4400D4FF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A2E" />
            <stroke android:width="1dp" android:color="#2A2A4A" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
