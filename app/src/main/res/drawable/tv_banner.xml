<?xml version="1.0" encoding="utf-8"?>
<!-- Banner Android TV : 320x180dp -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fond dégradé -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0A0A1A"
                android:centerColor="#12122A"
                android:endColor="#0A1A2A"
                android:type="linear" />
        </shape>
    </item>

    <!-- Accent line gauche -->
    <item android:right="280dp">
        <shape android:shape="rectangle">
            <solid android:color="#00D4FF" />
        </shape>
    </item>

    <!-- Texte simulé via inset (le vrai texte est dans le code) -->
    <item android:left="16dp" android:top="40dp" android:right="16dp" android:bottom="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>

</layer-list>
